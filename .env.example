# ---------------------------------------------------------------------------
# filebrowser — environment variables
# Copy this file to .env, fill in real values, then run ./deploy.sh
# ---------------------------------------------------------------------------

# ── Kubernetes ───────────────────────────────────────────────────────────────
# Namespace to deploy into (must exist or deploy.sh will create it)
HOMELAB_NAMESPACE=homelab

# ── Host path ────────────────────────────────────────────────────────────────
# Absolute path on the Mac that FileBrowser will expose at /srv inside the pod.
# The PersistentVolume uses this as a hostPath (virtiofs bind-mount via OrbStack).
# Default: your home Documents folder. Change if you want to expose a different dir.
HOMELAB_DOCUMENTS_PATH=/Users/yourname/Documents
